COMPOSE_PROJECT_NAME=feishu-timeline-staging
API_IMAGE_REPO=feishu-timeline-api
WEB_IMAGE_REPO=feishu-timeline-web

STAGING_HTTP_PORT=8080
STAGING_WEB_PORT=3100
STAGING_API_PORT=3101
STAGING_POSTGRES_PORT=15432
STAGING_REDIS_PORT=16379

POSTGRES_DB=feishu_timeline
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

FRONTEND_URL=http://localhost:8080
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/feishu_timeline?schema=public
REDIS_URL=redis://redis:6379

AUTH_MOCK_ENABLED=true
SESSION_COOKIE_NAME=ft_session
SESSION_TTL_SECONDS=28800

NOTIFICATION_QUEUE_ENABLED=true
NOTIFICATION_QUEUE_POLL_MS=5000
NOTIFICATION_OVERDUE_SCAN_MS=300000
NOTIFICATION_RETRY_DELAY_MS=5000
NOTIFICATION_MAX_RETRIES=3

OBJECT_STORAGE_PROVIDER=local
OBJECT_STORAGE_LOCAL_ROOT=/app/var/object-storage
OBJECT_STORAGE_ENDPOINT=http://minio.local
OBJECT_STORAGE_BUCKET=feishu-timeline-staging
OBJECT_STORAGE_ACCESS_KEY=staging-access-key
OBJECT_STORAGE_SECRET_KEY=staging-secret-key

FEISHU_APP_ID=staging-feishu-app-id
FEISHU_APP_SECRET=staging-feishu-app-secret
FEISHU_REDIRECT_URI=http://localhost:8080/login/callback
FEISHU_AUTHORIZATION_ENDPOINT=https://open.feishu.cn/open-apis/authen/v1/index

NEXT_PUBLIC_APP_NAME=轻卡新颜色开发项目管理系统
NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_FEISHU_APP_ID=staging-feishu-app-id
NEXT_PUBLIC_ENABLE_MOCK_LOGIN=true
