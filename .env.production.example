# Use this file as a review template when preparing:
# - /opt/feishu_timeline_app/apps/api/.env.production
# - /opt/feishu_timeline_app/apps/web/.env.production
# Not every variable belongs in both files.
# Do not commit real secrets, passwords, or tokens.

# Deployment metadata
# Current app code does not read these directly. They help keep root and subdomain roles clear.
ROOT_DOMAIN=all-too-well.com
APP_HOST=timeline.all-too-well.com
PUBLIC_APP_URL=https://timeline.all-too-well.com

# API runtime
NODE_ENV=production
HOST=127.0.0.1
PORT=3001
FRONTEND_URL=https://timeline.all-too-well.com
DATABASE_URL=postgresql://db_user:db_password@db-host:5432/db_name?schema=public
REDIS_URL=redis://redis-host:6379

# Notifications
NOTIFICATION_QUEUE_ENABLED=true
NOTIFICATION_QUEUE_POLL_MS=5000
NOTIFICATION_OVERDUE_SCAN_MS=300000
NOTIFICATION_RETRY_DELAY_MS=5000
NOTIFICATION_MAX_RETRIES=3

# Auth
AUTH_MOCK_ENABLED=false
SESSION_COOKIE_NAME=ft_session
SESSION_TTL_SECONDS=28800

# Object storage
# Current confirmed production attachment directory is /opt/feishu_timeline_app/var/object-storage.
# Keep this value aligned with the real runtime behavior on the target host.
OBJECT_STORAGE_PROVIDER=local
OBJECT_STORAGE_LOCAL_ROOT=/opt/feishu_timeline_app/var/object-storage
OBJECT_STORAGE_ENDPOINT=https://object-storage.example
OBJECT_STORAGE_BUCKET=replace-me
OBJECT_STORAGE_ACCESS_KEY=replace-me
OBJECT_STORAGE_SECRET_KEY=replace-me

# Feishu auth
FEISHU_APP_ID=replace-me
FEISHU_APP_SECRET=replace-me
FEISHU_REDIRECT_URI=https://timeline.all-too-well.com/login/callback
FEISHU_AUTHORIZATION_ENDPOINT=https://your-feishu-auth-endpoint.example

# Web public env
NEXT_PUBLIC_APP_NAME=轻卡新颜色开发项目管理系统
# Keep /api when timeline.all-too-well.com forwards same-origin /api/* requests to Nest.
NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_FEISHU_APP_ID=replace-me-if-needed
NEXT_PUBLIC_ENABLE_MOCK_LOGIN=false
