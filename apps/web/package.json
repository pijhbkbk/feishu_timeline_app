{
  "name": "@feishu-timeline/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env.example -- next dev --port 3000",
    "build": "next build",
    "start": "dotenv -e .env.example -- next start --hostname 127.0.0.1 --port 3000",
    "lint": "pnpm exec eslint src --ext .ts,.tsx --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "pnpm exec vitest run",
    "test:e2e": "node ./scripts/e2e-mainline.mjs",
    "playwright:test": "node ./scripts/playwright-runner.mjs",
    "playwright:test:raw": "pnpm exec playwright test"
  },
  "dependencies": {
    "next": "^15.5.18",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv-cli": "^8.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
